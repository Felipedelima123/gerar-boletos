{
  "name": "@f3dev/gerar-boletos",
  "version": "2.0.0",
  "description": "Gerar boletos bancários para vários bancos — biblioteca TypeScript + API REST",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "boletos-api": "dist/api/server.js"
  },
  "directories": {
    "example": "examples",
    "lib": "src",
    "test": "tests"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/api/server.ts",
    "start": "node dist/api/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "keywords": [
    "gerador",
    "boleto",
    "boletos",
    "bancario",
    "banco",
    "cecred",
    "sicredi",
    "ailos",
    "viacredi",
    "bradesco",
    "brasil",
    "itau",
    "caixa",
    "economica",
    "federal",
    "santander",
    "sicoob",
    "banrisul",
    "pix",
    "typescript",
    "api",
    "fastify"
  ],
  "author": {
    "name": "Francisco Lima",
    "email": "felipedelima43@gmail.com"
  },
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@fastify/sensible": "^5.6.0",
    "base64-stream": "^1.0.0",
    "date-fns": "^4.1.0",
    "fastify": "^4.28.1",
    "pdf-to-img": "^5.0.0",
    "pdfkit": "^0.15.2",
    "qrcode": "^1.5.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.13.4",
    "@types/qrcode": "^1.5.5",
    "tsup": "^8.2.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
